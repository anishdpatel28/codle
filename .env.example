# Supabase project credentials.
# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings -> API). .env.local is gitignored — never commit real keys.
#
# The app runs in a local, no-backend fallback mode when these are unset, so
# you can play the daily game without Supabase configured.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
